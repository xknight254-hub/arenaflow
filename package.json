{
  "name": "arenaflow",
  "version": "1.0.0",
  "description": "Tournament bracket engine with built-in result verification — supports knockout, league, multi-bracket, and Swiss formats. OCR-powered screenshot validation with fraud detection.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "node --test dist/**/*.test.js"
  },
  "keywords": [
    "tournament",
    "bracket",
    "esports",
    "efootball",
    "ocr",
    "verification",
    "fraud-detection",
    "knockout",
    "swiss",
    "round-robin"
  ],
  "author": "xknight254-hub",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "better-sqlite3": "^11.3.0",
    "multer": "^1.4.5-lts.1",
    "tesseract.js": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/uuid": "^10.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.0",
    "typescript": "^5.5.3",
    "tsx": "^4.19.0",
    "eslint": "^9.9.0",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
